# =============================================================================
# TaxForge environment configuration
#
# Every value below is optional in the sense that the app boots and runs
# without it — each subsystem falls back to a safe local/demo mode when its
# config is missing (heuristic classifier, in-memory rate limit, JSON file
# storage, mock payment adapter). See the comment on each variable for what
# breaks if you skip it, and README.md's "What's real vs mocked" table.
#
# ⚠️  DEMO-MODE VARIABLES MUST BE REPLACED BEFORE GOING LIVE ON OKX.AI.
#     A listed, callable ASP that hasn't set X402_FACILITATOR_URL is not
#     actually verifying payments — see src/lib/x402/facilitator.ts.
# =============================================================================

# --- AI classification ---
# Without this, classification falls back to the deterministic heuristic
# engine in src/lib/ai/classify.ts (works fine, just less nuanced on
# ambiguous transactions).
ANTHROPIC_API_KEY=

# --- Chain access (X Layer) ---
# Both rpc.xlayer.tech and xlayerrpc.okx.com are real public RPC endpoints
# for X Layer mainnet (chain 196). Public RPCs are rate-limited
# (100 req/s/IP) — get a dedicated RPC (QuickNode/Chainstack/BlockPI/etc.)
# before real agent traffic.
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_CHAIN_ID=196
ETH_RPC_URL=https://eth.llamarpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org

# Address of the on-chain attestation registry contract on X Layer where
# report hashes get anchored (via the OKX payment adapter's anchorHash()).
ATTESTATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# --- Real multi-chain transaction ingestion ---
# Powers GET /api/tax/ingest. Without these, that endpoint returns bundled
# sample data with "source": "sample" clearly marked in the response —
# it will NOT silently pretend sample data is live.
#
# Etherscan V2 unified API — one key covers ethereum/arbitrum/base via the
# chainid param. Get a free key at https://etherscan.io/apis
ETHERSCAN_API_KEY=
# OKLink explorer API (X Layer). Get a key at https://www.oklink.com/docs/en/#quickstart-guide-getting-started
OKLINK_API_KEY=

# --- OKX / Onchain OS ---
# Populated after registering TaxForge as an ASP. See
# docs/onchain-os-registration.md. OKX_ASP_ID is surfaced in /health.
OKX_ASP_ID=
# For OKX CEX market/price data if you wire in live pricing (see the
# priceUsdAtTx=0 caveat in src/lib/chain/explorers.ts).
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# --- x402 (pay-per-call) ---
# THE MOST IMPORTANT VARIABLE FOR GOING LIVE. Unset = demo mode (payments
# are not actually verified — see src/lib/x402/facilitator.ts). Set this to
# the real facilitator URL OKX assigns your ASP during Onchain OS
# registration to switch on real /verify + /settle calls.
X402_FACILITATOR_URL=
X402_RECEIVING_ADDRESS=0x0000000000000000000000000000000000000000
X402_NETWORK=x-layer
X402_ASSET=USDT
# Decimals for the chosen asset — 6 is correct for USDT/USDC on X Layer and
# most EVM chains. Wrong decimals here means agents will over- or
# under-pay by orders of magnitude, so double check against your token's
# actual contract if you switch assets.
X402_ASSET_DECIMALS=6
X402_PRICE_SIMULATE=0.15
X402_PRICE_CLASSIFY=0.05
X402_PRICE_REPORT=2.50

# --- Storage ---
# Set both to switch from the local JSON file store (fine for `npm run
# dev`, NOT reliable on Vercel's ephemeral serverless filesystem) to real
# persistent storage via Upstash Redis's REST API. Free tier is enough to
# go live. Create a database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Rate limiting ---
# Automatically becomes Upstash-backed (correct across multiple serverless
# instances) once the Upstash vars above are set; otherwise in-memory
# (single-instance only — fine for dev).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_CALLS=120
