# --- AI classification ---
# If unset, TaxForge falls back to the deterministic heuristic classifier in
# src/lib/ai/classify.ts so the demo still runs with zero keys configured.
ANTHROPIC_API_KEY=

# --- Chain access ---
XLAYER_RPC_URL=https://xlayerrpc.okx.com
XLAYER_CHAIN_ID=196
ETH_RPC_URL=https://eth.llamarpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org

# Address of the (mock-able) on-chain attestation registry contract on X Layer
# where report hashes get anchored. See src/lib/chain/xlayer.ts
ATTESTATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# --- OKX / Onchain OS ---
# Populated after registering TaxForge as an ASP in the Onchain OS console.
# See docs/onchain-os-registration.md
OKX_ASP_ID=
OKX_PAYMENT_SDK_API_KEY=
OKX_PAYMENT_SDK_SECRET=

# --- x402 (pay-per-call) ---
X402_RECEIVING_ADDRESS=0x000000000000000000000000000000000000000
X402_NETWORK=x-layer
X402_ASSET=USDC
X402_PRICE_SIMULATE=0.02
X402_PRICE_CLASSIFY=0.01
X402_PRICE_REPORT=0.50
X402_FACILITATOR_URL=https://facilitator.x402.okx.com

# --- Storage (demo default: local JSON file store, swap for Supabase in prod) ---
DB_DRIVER=jsonfile
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_CALLS=120
